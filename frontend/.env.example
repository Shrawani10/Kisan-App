# ============================================================
# Kisan Chat - Frontend Environment Example
# ============================================================
# 1) Copy this file to .env.local for local development.
# 2) Fill in your Supabase values.
# 3) Keep backend secrets/API keys only in backend/.env (do not put them here).
# ============================================================

# Backend API base URL used by frontend fetch calls.
# Keep /api to use Vite proxy in local dev.
VITE_API_BASE_URL=/api

# Vite dev proxy target backend URL.
VITE_BACKEND_URL=http://localhost:8000

# Supabase configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Example:
# VITE_SUPABASE_URL=https://xyzabcdef.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...
