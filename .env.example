# ============================================================
# Kisan Chat - Backend Environment Variables (Server-side secrets)
# ============================================================
# 1) Set these in Vercel Settings > Environment Variables
# 2) Or create .env.local for local development
# 3) NEVER commit real credentials to Git
# ============================================================

# # Azure Foundry / OpenAI
AZURE_OPENAI_ENDPOINT=https://proj-kisan.openai.azure.com/openai/v1
AZURE_OPENAI_KEY=<your-foundry-api-key>
PROJECT_CONNECTION_STRING=//proj-kisan.services.ai.azure.com/api/projects/proj-kisan
AZURE_FOUNDRY_AGENT_ID=<your-agent-id>
AZURE_API_VERSION=2024-10-21

# Supabase (User Authentication)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=<your-supabase-anon-key>
SUPABASE_JWT_SECRET=<your-supabase-jwt-secret>

# Runtime Environment
NODE_ENV=production
